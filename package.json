{
  "name": "bank-integration",
  "version": "1.0.0",
  "private": true,
  "description": "Self-polling background worker that fetches payments from S/4HANA, dedups against a local JSON DB, and submits new transactions via doSampathTran",
  "main": "srv/bankIntegration.js",
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    }
  },
  "scripts": {
    "start": "node srv/bankIntegration.js",
    "worker": "node srv/bankIntegration.js",
    "sync:business-partners": "node srv/businessPartnerSync.js",
    "test:token": "node scripts/test-token.js",
    "test:bank": "node scripts/test-bank-transaction.js"
  },
  "dependencies": {
    "@cap-js/hana": "^1.9.0",
    "@sap/cds": "^8.9.1",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  }
}
