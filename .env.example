# Bank (Sampath) API configuration
BANK_BASE_URL=https://bank-host.example.com
BANK_TOKEN_PATH=/oauth2/token
BANK_TRANSACTION_PATH=/doSampathTran

# OAuth2 client credentials for the bank login endpoint
BANK_CLIENT_ID=
BANK_CLIENT_SECRET=
BANK_GRANT_TYPE=client_credentials
BANK_TOKEN_SCOPE=api_banking

# Full Authorization header value sent on the token request, e.g. "Basic <base64(client_id:client_secret)>"
BANK_TOKEN_AUTHORIZATION=

# Defaults used when the incoming event does not carry these fields
BANK_DEFAULT_FROM_ACC=001410003577
BANK_DEFAULT_BANK_CODE=7278

# S/4HANA payment API polled by the background worker (srv/bankIntegration.js)
S4_API_URL=https://your-s4hana-host.example.com/sap/opu/odata4/sap/api_payfnpaymentapibasic/srvd_a2x/sap/payfnpayment/0001/PayFnPaymentAPIBasic
S4_USER=
# Wrap in single quotes if the password contains a '#' or other special characters,
# otherwise dotenv will silently truncate the value at the '#' (treats it as a comment).
S4_PASSWORD=

# Poll interval in milliseconds (default 300000 = 5 minutes)
POLL_INTERVAL_MS=300000

# Local JSON "database" used to dedupe already-processed transactions across restarts
PROCESSED_DB_PATH=db/processed-transactions.json

# Directory where the worker writes its log file (bank-integration.log)
LOG_DIR=logs
